SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=irri_ai
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Odia speech-to-text is handled locally by AI4Bharat IndicConformer
# (queries/services/indic_stt.py). Model is downloaded once on first use; no API key.

# Picky Assist (WhatsApp gateway)
PICKY_ASSIST_TOKEN=your-picky-assist-token
PICKY_ASSIST_WEBHOOK_SECRET=your-webhook-secret
PICKY_ASSIST_SEND_URL=https://api.pickyassist.com/v1/outbound/send

# Feature flags
USE_LOCAL_EMBEDDINGS=0
